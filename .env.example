APP_NAME=ПечьДаЛожка Backend
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

POSTGRES_DB=pechdalojka
POSTGRES_USER=pechdalojka
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+psycopg://pechdalojka:change-me-postgres-password@postgres:5432/pechdalojka

REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

S3_ENDPOINT_URL=http://minio:9000
S3_REGION_NAME=us-east-1
S3_BUCKET_NAME=pechdalojka-recipes
S3_MAX_RETRY_ATTEMPTS=3
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_HOST_BIND=127.0.0.1
S3_ACCESS_KEY_ID=change-me-minio-user
S3_SECRET_ACCESS_KEY=change-me-minio-password
S3_USE_SSL=false
S3_PUBLIC_BASE_URL=
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_PRESIGNED_URL_EXPIRATION_SECONDS=900

OPENAI_API_KEY=sk-your-openai-key
OPENAI_PROJECT_ID=
OPENAI_TEXT_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_TEXT_TIMEOUT_SECONDS=60
OPENAI_IMAGE_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRY_ATTEMPTS=3
OPENAI_MAX_OUTPUT_TOKENS=1800

ADMIN_BEARER_TOKEN=change-me-to-a-strong-random-token
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_RATE_LIMIT_REQUESTS_PER_MINUTE=20

GENERATION_LOCK_TIMEOUT_SECONDS=1800
GENERATION_STALE_AFTER_SECONDS=2400
GENERATION_MAX_RETRY_COUNT=3
AUTO_PUBLISH_GENERATED_RECIPES=false
DEFAULT_RECIPE_LANGUAGE_CODE=ru-RU
DEFAULT_CUISINE_CONTEXT=modern home cooking with Russian-friendly ingredients
DEFAULT_DIETARY_CONTEXT=balanced
DEFAULT_EXCLUDED_INGREDIENTS=
DEFAULT_IMAGE_STYLE=editorial food photography
DEFAULT_MAX_INGREDIENTS=14
DEFAULT_MAX_STEPS=8

REQUEST_TIMEOUT_SECONDS=15
HTTP_CONNECT_TIMEOUT_SECONDS=5
