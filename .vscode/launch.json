{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: uvicorn --reload",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:create_app",
        "--factory",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env.local",
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    }
  ]
}
